{
	"name": "discord-bot",
	"version": "0.0.0",
	"description": "",
	"private": true,
	"type": "module",
	"scripts": {
		"start": "pnpm recursive --include-workspace-root run build && node --env-file=.env dist/index.js | pino-pretty",
		"build": "node esbuild.js",
		"lint": "biome check --write ./src",
		"tsc": "tsc --noEmit",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"changeset": "changeset",
		"version-packages": "changeset version",
		"release": "pnpm recursive run build && changeset publish",
		"prompt-benchmark": "tsx --env-file=.env src/benchmarks/promptBenchmark.ts"
	},
	"packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
	"dependencies": {
		"@ai-sdk/mistral": "^3.0.39",
		"@discord-player/extractor": "^7.2.0",
		"@kubernetes/client-node": "^1.4.0",
		"@sentry/node": "^10.57.0",
		"bufferutil": "^4.1.0",
		"discord-player": "^7.2.0",
		"discord-player-googlevideo": "workspace:*",
		"discord-player-spotify": "^1.1.9",
		"discord.js": "^14.26.4",
		"ioredis": "^5.11.1",
		"pino": "^10.3.1",
		"sodium-native": "^5.1.0",
		"ulid": "^3.0.2",
		"zlib-sync": "^0.1.10"
	},
	"devDependencies": {
		"@ai-sdk/openai": "^3.0.71",
		"@biomejs/biome": "catalog:",
		"@changesets/cli": "^2.31.0",
		"@discordjs/rest": "^2.6.1",
		"@sentry/esbuild-plugin": "^5.3.0",
		"@snazzah/davey": "^0.1.11",
		"@types/node": "catalog:",
		"@vitest/coverage-v8": "catalog:",
		"ai": "^6.0.203",
		"date-fns": "^4.4.0",
		"esbuild": "^0.28.0",
		"esbuild-plugin-pino": "2.3.3",
		"fuse.js": "^7.4.2",
		"memoize": "^11.0.0",
		"p-debounce": "^5.1.0",
		"p-queue": "^9.3.0",
		"pino-pretty": "^13.1.3",
		"pretty-bytes": "^7.1.0",
		"transliteration": "^2.6.1",
		"tsx": "^4.22.4",
		"typescript": "catalog:",
		"vitest": "catalog:",
		"zod": "^4.4.3"
	}
