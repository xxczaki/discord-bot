{
	"name": "discord-bot",
	"version": "0.0.0",
	"description": "",
	"private": true,
	"type": "module",
	"scripts": {
		"start": "pnpm recursive --include-workspace-root run build && node --env-file=.env dist/index.js | pino-pretty",
		"build": "node esbuild.js",
		"lint": "biome check --write ./src",
		"tsc": "tsc --noEmit",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"changeset": "changeset",
		"version-packages": "changeset version",
		"release": "pnpm recursive run build && changeset publish",
		"prompt-benchmark": "tsx --env-file=.env src/benchmarks/promptBenchmark.ts"
	},
	"packageManager": "pnpm@11.3.0+sha512.2c403d6594527287672b1f7056343a1f7c3634036a67ffabfcc2b3d7595d843768f8787148d1b57cf7956c90606bbd192857c363af19e96d2d0ec9ec5741d215",
	"dependencies": {
		"@ai-sdk/mistral": "^3.0.37",
		"@discord-player/extractor": "^7.2.0",
		"@kubernetes/client-node": "^1.4.0",
		"@sentry/node": "^10.53.1",
		"bufferutil": "^4.1.0",
		"discord-player": "^7.2.0",
		"discord-player-googlevideo": "workspace:*",
		"discord-player-spotify": "^1.1.9",
		"discord.js": "^14.26.4",
		"ioredis": "^5.10.1",
		"pino": "^10.3.1",
		"sodium-native": "^5.1.0",
		"ulid": "^3.0.2",
		"zlib-sync": "^0.1.10"
	},
	"devDependencies": {
		"@ai-sdk/openai": "^3.0.65",
		"@biomejs/biome": "catalog:",
		"@changesets/cli": "^2.31.0",
		"@discordjs/rest": "^2.6.1",
		"@sentry/esbuild-plugin": "^5.3.0",
		"@snazzah/davey": "^0.1.11",
		"@types/node": "catalog:",
		"@vitest/coverage-v8": "catalog:",
		"ai": "^6.0.191",
		"date-fns": "^4.3.0",
		"esbuild": "^0.28.0",
		"esbuild-plugin-pino": "2.3.3",
		"fuse.js": "^7.3.0",
		"memoize": "^11.0.0",
		"p-debounce": "^5.1.0",
		"p-queue": "^9.3.0",
		"pino-pretty": "^13.1.3",
		"pretty-bytes": "^7.1.0",
		"transliteration": "^2.6.1",
		"tsx": "^4.22.3",
		"typescript": "catalog:",
		"vitest": "catalog:",
		"zod": "^4.4.3"
	}
}
