{
	"name": "discord-player-googlevideo",
	"version": "0.2.5",
	"description": "A discord-player extractor using YouTube SABR streaming with googlevideo and youtubei.js",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"build": "tsc",
		"clean": "rm -rf dist",
		"lint": "biome check --write ./src",
		"tsc": "tsc --noEmit",
		"test": "vitest run",
		"prepublishOnly": "pnpm clean && pnpm build && pnpm test"
	},
	"keywords": [
		"discord",
		"discord-player",
		"youtube",
		"extractor",
		"music",
		"streaming",
		"sabr",
		"youtubei",
		"googlevideo"
	],
	"author": "xxczaki",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/xxczaki/discord-bot.git",
		"directory": "packages/discord-player-googlevideo"
	},
	"bugs": {
		"url": "https://github.com/xxczaki/discord-bot/issues"
	},
	"homepage": "https://github.com/xxczaki/discord-bot/tree/main/packages/discord-player-googlevideo#readme",
	"peerDependencies": {
		"discord-player": "^7.2.0"
	},
	"dependencies": {
		"bgutils-js": "^3.2.0",
		"googlevideo": "^4.0.4",
		"jsdom": "^29.1.1",
		"youtubei.js": "^17.0.1"
	},
	"devDependencies": {
		"@biomejs/biome": "catalog:",
		"@types/jsdom": "^28.0.1",
		"@types/node": "catalog:",
		"@vitest/coverage-v8": "catalog:",
		"discord-player": "^7.2.0",
		"typescript": "catalog:",
		"vitest": "catalog:"
	},
	"packageManager": "pnpm@11.2.2+sha512.36e6621fad506178936455e70247b8808ef4ec25797a9f437a93281a020484e2607f6a469a22e982987c3dbb8866e3071514ab10a4a1749e06edcd1ec118436f"
}
